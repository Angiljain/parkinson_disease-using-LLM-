# Environment Variables for PD Screening System
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (for GPT-4o, GPT-3.5-turbo, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API Key (for Mistral models)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Custom configuration path
CONFIG_PATH=config.yaml

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Custom paths
KNOWLEDGE_BASE_PATH=./data/knowledge_base
VECTOR_STORE_PATH=./data/chroma_db

# Optional: API Configuration (for Flask)
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# Optional: Model Configuration Overrides
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=1000

# Optional: RAG Configuration Overrides
# RAG_TOP_K=3
# RAG_SIMILARITY_THRESHOLD=0.7
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2